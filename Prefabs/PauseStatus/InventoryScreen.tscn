[node name="Label" type="Label" parent="Panel/TabContainer/Status/Equipment/HBoxContainer" unique_id=1409067442]
custom_minimum_size = Vector2(320, 300)
layout_mode = 2
size_flags_horizontal = 3
theme_override_colors/font_color = Color(0.6039216, 0.21960784, 0.27450982, 1)
theme_override_font_sizes/font_size = 15
text = "We're no strangers to love, you know the rules and so do I. A full commitment's what I'm thinking of, you wouldn't get this from any other guy. I just want to tell you how I'm feeling. Gotta make you understand!

Never gonna give you up, never gonna let you down, never gonna run around and desert you. Never gonna make you cry, never gonna say goodbye, never gonna tell a lie and hurt you.

We've known each other, for so long. Your hearts been aching but you're to shy to say it. Inside, we both know what's been going on. We know the game, and we're gonna play it.

And if you ask me how I'm feeling, don't tell me you're too blind to see!"
autowrap_mode = 2

