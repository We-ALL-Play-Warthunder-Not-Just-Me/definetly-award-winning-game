[node name="Label" type="Label" parent="Text" unique_id=968796704]
offset_left = 100.0
offset_top = 96.0
offset_right = 275.0
offset_bottom = 601.0
theme_override_fonts/font = ExtResource("8_brmfm")
theme_override_font_sizes/font_size = 8
text = "Hey. Listen. You don't want to go down there. That's the end down there. I know there's not much, but do you really want the game to end? Think about how much bigger you can make number go up. Number go 'brrrrrr', am I right?



...



This hasn't convinced you, has it?

You're still reading. You want to see the end. It's not pretty. It's rather mundane, actually.



But that's life, I suppose. We all live and die eventually, even fun little game ideas you make with your friends. It was a nice ride. I hope you enjoyed it.

Did you make it to the town? I know it ain't much, but I tried to make it lively. My friends also did their best with the code, especially with this being their first proper jam. Show them some love and respect, I'm sure they'd appreciate it. I'm damn proud of them and what we've managed to accomplish in out one month timelimit.

This was honestly really fun to just have a few laughs and headaches with friends over making a game together.

So even though we're at the end of this game and the experience is more or less over, I will cherish the memories made, and I hope that you, Player, are able to walk away with a bit of a smile on your face today. 
                              -G"
horizontal_alignment = 1
autowrap_mode = 2

